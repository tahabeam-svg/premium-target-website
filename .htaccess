<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # API: Contact form (PHP)
    RewriteRule ^api/contact$ api/contact.php [L,QSA]

    # API: Checkout / Order (PHP)
    RewriteRule ^api/checkout$ api/checkout.php [L,QSA]

    # API: Portfolio list
    RewriteRule ^api/portfolio$ api/portfolio.json [L]

    # API: Single portfolio item by slug
    RewriteRule ^api/portfolio/([a-z0-9-]+)$ api/portfolio/$1.json [L]

    # API: Packages list
    RewriteRule ^api/packages$ api/packages.json [L]

    # API: Blog list
    RewriteRule ^api/blog$ api/blog.json [L]

    # API: Single blog post by slug
    RewriteRule ^api/blog/([a-z0-9-]+)$ api/blog/$1.json [L]

    # API: Testimonials list
    RewriteRule ^api/testimonials$ api/testimonials.json [L]

    # Serve JSON with correct Content-Type
    <FilesMatch "\.json$">
        Header set Content-Type "application/json; charset=utf-8"
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>

    # SPA: All other routes go to index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Enable mod_headers
<IfModule mod_headers.c>
    # Cache static assets
    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # No cache for HTML and PHP
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# Enable Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/json application/javascript text/xml application/xml
</IfModule>
